---
import Layout from '../layouts/Layout.astro';
import IllustrationVigo from '../components/IllustrationVigo.astro';
---

<Layout title="Contact — Julien Klein" description="Coaching, advisory, ou juste envie d'échanger.">
  <div style="max-width: 640px; margin: 0 auto; padding: 0 1.5rem;">

    <section style="padding: 5rem 0 3rem; display: grid; grid-template-columns: 1fr auto; gap: 2rem; align-items: start;">
      <div>
        <p style="font-size: 0.8rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--muted); margin-bottom: 1rem;">Contact</p>
        <h1 style="font-size: clamp(2rem, 4vw, 2.8rem); margin: 0 0 1.5rem; line-height: 1.1;">
          Démarrer<br/><em style="color: var(--accent2);">une conversation.</em>
        </h1>
        <p style="color: var(--muted); font-size: 0.95rem; line-height: 1.8; max-width: 420px; margin-bottom: 2.5rem;">
          Coaching, advisory, question sur un article, ou juste envie d'échanger sur Meta Ads, TDAH ou les systèmes de productivité.
        </p>

        <div style="display: flex; flex-direction: column; gap: 1rem;">
          <a href="mailto:julienklein20@gmail.com" style="display: flex; align-items: center; gap: 1rem; padding: 1.2rem 1.5rem; background: var(--card); border: 1px solid var(--border); border-radius: 12px; transition: border-color 0.2s;">
            <span style="font-size: 1.2rem;">✉️</span>
            <div>
              <div style="font-size: 0.85rem; font-weight: 500; margin-bottom: 0.2rem;">Email</div>
              <div style="font-size: 0.8rem; color: var(--muted);">julienklein20@gmail.com</div>
            </div>
            <span style="color: var(--muted); margin-left: auto;">→</span>
          </a>

          <a href="https://linkedin.com/in/julienklein" target="_blank" style="display: flex; align-items: center; gap: 1rem; padding: 1.2rem 1.5rem; background: var(--card); border: 1px solid var(--border); border-radius: 12px;">
            <span style="font-size: 1.2rem;">💼</span>
            <div>
              <div style="font-size: 0.85rem; font-weight: 500; margin-bottom: 0.2rem;">LinkedIn</div>
              <div style="font-size: 0.8rem; color: var(--muted);">Julien Klein</div>
            </div>
            <span style="color: var(--muted); margin-left: auto;">→</span>
          </a>

          <a href="https://newsletter.vigoenville.fr" target="_blank" style="display: flex; align-items: center; gap: 1rem; padding: 1.2rem 1.5rem; background: var(--bg-warm); border: 1px solid var(--border); border-radius: 12px;">
            <span style="font-size: 1.2rem;">🐾</span>
            <div>
              <div style="font-size: 0.85rem; font-weight: 500; margin-bottom: 0.2rem;">Vigo en Ville</div>
              <div style="font-size: 0.8rem; color: var(--muted);">La newsletter — un vendredi sur deux</div>
            </div>
            <span style="color: var(--muted); margin-left: auto;">→</span>
          </a>
        </div>
      </div>

      <div style="width: 140px; margin-top: 2rem; opacity: 0.8;">
        <IllustrationVigo />
      </div>
    </section>

  </div>
</Layout>
