---
import Layout from '../layouts/Layout.astro';
import IllustrationVigo from '../components/IllustrationVigo.astro';
---

<Layout title="Contact — Julien Klein" description="Coaching, advisory, ou juste envie d'échanger.">
  <div style="max-width: 640px; margin: 0 auto; padding: 0 1.5rem;">

    <section style="padding: 5rem 0 3rem; display: grid; grid-template-columns: 1fr auto; gap: 2rem; align-items: start;">
      <div>
        <p style="font-size: 0.8rem; letter-spacing: 0.12em; text-transform: uppercase; color: #8B7355; margin-bottom: 1rem;">Contact</p>
        <h1 style="font-size: clamp(2rem, 4vw, 2.8rem); margin: 0 0 1.5rem; line-height: 1.1; font-family: 'Playfair Display', serif; color: #2C2416;">
          Démarrer<br/><em style="color: #A85C3A;">une conversation.</em>
        </h1>
        <p style="color: #8B7355; font-size: 0.95rem; line-height: 1.8; max-width: 420px; margin-bottom: 2.5rem;">
          Coaching, advisory, question sur un article, ou juste envie d'échanger sur Growth, TDAH ou la relation chien/humain.
        </p>

        <div style="display: flex; flex-direction: column; gap: 1rem;">
          <a href="mailto:julienklein20@gmail.com" style="display: flex; align-items: center; gap: 1rem; padding: 1.2rem 1.5rem; background: #FAF7F2; border: 1px solid #D4C9B5; border-radius: 12px; color: #2C2416; text-decoration: none;">
            <span style="width: 36px; height: 36px; background: #EDE7D9; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 1rem; flex-shrink: 0;">✉</span>
            <div>
              <div style="font-size: 0.88rem; font-weight: 500; margin-bottom: 0.2rem; color: #2C2416;">Email</div>
              <div style="font-size: 0.8rem; color: #8B7355;">julienklein20@gmail.com</div>
            </div>
            <span style="color: #8B7355; margin-left: auto; font-size: 1rem;">→</span>
          </a>

          <a href="https://linkedin.com/in/julienklein" target="_blank" style="display: flex; align-items: center; gap: 1rem; padding: 1.2rem 1.5rem; background: #FAF7F2; border: 1px solid #D4C9B5; border-radius: 12px; color: #2C2416; text-decoration: none;">
            <span style="width: 36px; height: 36px; background: #EDE7D9; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 1rem; flex-shrink: 0;">in</span>
            <div>
              <div style="font-size: 0.88rem; font-weight: 500; margin-bottom: 0.2rem; color: #2C2416;">LinkedIn</div>
              <div style="font-size: 0.8rem; color: #8B7355;">Julien Klein</div>
            </div>
            <span style="color: #8B7355; margin-left: auto; font-size: 1rem;">→</span>
          </a>

          <a href="mailto:julienklein20@gmail.com?subject=Inscription Vigo en Ville" style="display: flex; align-items: center; gap: 1rem; padding: 1.2rem 1.5rem; background: #EDE7D9; border: 1px solid #D4C9B5; border-radius: 12px; color: #2C2416; text-decoration: none;">
            <span style="width: 36px; height: 36px; background: #D4C9B5; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 1rem; flex-shrink: 0;">🐾</span>
            <div>
              <div style="font-size: 0.88rem; font-weight: 500; margin-bottom: 0.2rem; color: #2C2416;">Vigo en Ville</div>
              <div style="font-size: 0.8rem; color: #8B7355;">La newsletter — un vendredi sur deux</div>
            </div>
            <span style="color: #8B7355; margin-left: auto; font-size: 1rem;">→</span>
          </a>
        </div>
      </div>

      <div style="width: 140px; margin-top: 2rem; opacity: 0.8;">
        <IllustrationVigo />
      </div>
    </section>

  </div>
</Layout>
