---
interface Props {
  title?: string;
  description?: string;
}
const { title = "Julien Klein", description = "Consultant Growth & Media Buyer. TDAH, IA, et un chien qui me remet à l'heure." } = Astro.props;
---
<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400;1,600&family=Inter:wght@300;400;500&display=swap" rel="stylesheet" />
    <style is:global>
      @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400;1,600&family=Inter:wght@300;400;500&display=swap');

      :root {
        --bg: #F5F0E8;
        --bg-warm: #EDE7D9;
        --text: #2C2416;
        --muted: #8B7355;
        --accent: #5C7A4E;
        --accent2: #A85C3A;
        --border: #D4C9B5;
        --card: #FAF7F2;
      }

      * { box-sizing: border-box; }

      html {
        background-color: var(--bg);
        color: var(--text);
        font-family: 'Inter', sans-serif;
        font-weight: 300;
        line-height: 1.7;
      }

      body { margin: 0; padding: 0; }

      h1, h2, h3 {
        font-family: 'Playfair Display', serif;
        font-weight: 600;
        line-height: 1.2;
      }

      a { color: inherit; text-decoration: none; }
      a:hover { color: var(--accent2); }

      .tag {
        display: inline-block;
        font-size: 0.7rem;
        font-weight: 500;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        padding: 0.2rem 0.6rem;
        border: 1px solid var(--border);
        border-radius: 999px;
        color: var(--muted);
      }
      .tag.meta { border-color: #A85C3A; color: #A85C3A; }
      .tag.ia { border-color: #5C7A4E; color: #5C7A4E; }
      .tag.perso { border-color: #7A5C8B; color: #7A5C8B; }
    </style>
  </head>
  <body>
    <nav style="max-width: 960px; margin: 0 auto; padding: 2rem 1.5rem; display: flex; justify-content: space-between; align-items: center;">
      <a href="/" style="font-family: 'Playfair Display', serif; font-size: 1.1rem; font-weight: 600;">Julien Klein</a>
      <div style="display: flex; gap: 2rem; font-size: 0.9rem; color: var(--muted);">
        <a href="/blog">Notes</a>
        <a href="/parcours">Méthode</a>
        <a href="/ressources">Ressources</a>
        <a href="/contact">Contact</a>
      </div>
    </nav>
    <main>
      <slot />
    </main>
    <footer style="max-width: 960px; margin: 6rem auto 0; padding: 2rem 1.5rem; border-top: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center; font-size: 0.8rem; color: var(--muted);">
      <span>Julien Klein · 2026</span>
      <div style="display: flex; gap: 1.5rem;">
        <a href="https://linkedin.com/in/julienklein" target="_blank">LinkedIn</a>
        <a href="/contact">Contact</a>
      </div>
    </footer>
  </body>
</html>
