---
import Layout from '../layouts/Layout.astro';

const categories = [
  {
    id: "skills",
    title: "Skills Claude Code",
    desc: "Mes commandes slash — workflows réutilisables.",
    color: "#5C7A4E",
    items: [
      { slug: "post-linkedin", name: "/post-linkedin", desc: "Génère un post LinkedIn dans mon style depuis une idée brute ou un angle." },
      { slug: "score-linkedin", name: "/score-linkedin", desc: "Panel de 5 experts qui score un post avant publication. Minimum 85/100." },
      { slug: "capture", name: "/capture", desc: "Range une idée, observation ou insight au bon endroit sans friction." },
      { slug: "ingest", name: "/ingest", desc: "Ingère une ressource externe dans le Second Brain avec résumé structuré." },
      { slug: "angle", name: "/angle", desc: "Trouve des angles éditoriaux forts en connectant des concepts du Garden." },
      { slug: "mktg-trend-scout", name: "/mktg:trend-scout", desc: "Scanne HN, Reddit, Google Trends et X pour les sujets qui montent sur ton domaine." },
      { slug: "writing-unslop", name: "/writing:unslop", desc: "Filtre anti-slop — retire la signature IA d'un texte sans toucher aux idées." },
    ]
  },
  {
    id: "mcp",
    title: "Serveurs MCP",
    desc: "Les connecteurs qui relient Claude à mes outils.",
    color: "#A85C3A",
    items: [
      { slug: "firecrawl", name: "Firecrawl", desc: "Scraping web avancé — Notion, articles, sites derrière auth." },
      { slug: "slack", name: "Slack", desc: "Lire et poster dans mes channels directement depuis Claude." },
      { slug: "figma", name: "Figma", desc: "Accès aux designs, composants et variables de mes fichiers." },
      { slug: "google-drive", name: "Google Drive", desc: "Lecture et création de fichiers dans mes drives." },
      { slug: "notion", name: "Notion", desc: "Accès en lecture/écriture à mes bases de données Notion." },
      { slug: "n8n", name: "n8n", desc: "Déclenchement de workflows d'automatisation depuis Claude." },
    ]
  },
  {
    id: "outils",
    title: "Outils du quotidien",
    desc: "Les apps qui font tourner mon système.",
    color: "#7A5C8B",
    items: [
      { slug: "obsidian", name: "Obsidian", desc: "Second Brain — notes, garden, projets, capture." },
      { slug: "vscode", name: "VSCode", desc: "Éditeur principal avec Claude Code intégré." },
      { slug: "claude-code", name: "Claude Code", desc: "CLI IA dans le terminal — agents, skills, MCP, mémoire persistante." },
      { slug: "wispr-flow", name: "Wispr Flow", desc: "Dictée vocale IA — parler au lieu de taper, partout sur le Mac." },
      { slug: "granola", name: "Granola", desc: "Prise de notes IA pendant les réunions." },
      { slug: "figma-outil", name: "Figma", desc: "Design, maquettes et composants visuels." },
      { slug: "meta-ads", name: "Meta Ads Manager", desc: "Gestion et analyse des campagnes Meta." },
    ]
  },
];
---

<Layout title="Ressources — Julien Klein" description="Mes Skills Claude Code, serveurs MCP et outils du quotidien.">
  <div style="max-width: 960px; margin: 0 auto; padding: 0 1.5rem;">

    <section style="padding: 4rem 0 2rem;">
      <p style="font-size: 0.8rem; letter-spacing: 0.12em; text-transform: uppercase; color: #8B7355; margin-bottom: 1rem;">Ma boîte à outils</p>
      <h1 style="font-size: clamp(2rem, 4vw, 3rem); margin: 0 0 1rem; font-family: 'Playfair Display', serif; color: #2C2416;">Ce qui fait tourner<br/><em style="color: #A85C3A;">le système.</em></h1>
      <p style="color: #8B7355; font-size: 1rem; line-height: 1.7; max-width: 480px; margin-bottom: 2rem;">
        Pas de software sans usage concret. Chaque outil ici a survécu 6 mois de test quotidien.
      </p>
      <!-- Ancres de navigation -->
      <div style="display: flex; gap: 0.6rem; flex-wrap: wrap;">
        <a href="#skills" style="font-size: 0.8rem; padding: 0.35rem 0.9rem; border: 1px solid #5C7A4E; border-radius: 999px; color: #5C7A4E; text-decoration: none;">Skills Claude Code</a>
        <a href="#mcp" style="font-size: 0.8rem; padding: 0.35rem 0.9rem; border: 1px solid #A85C3A; border-radius: 999px; color: #A85C3A; text-decoration: none;">Serveurs MCP</a>
        <a href="#outils" style="font-size: 0.8rem; padding: 0.35rem 0.9rem; border: 1px solid #7A5C8B; border-radius: 999px; color: #7A5C8B; text-decoration: none;">Outils du quotidien</a>
      </div>
    </section>

    {categories.map(cat => (
      <section id={cat.id} style="margin-bottom: 4rem; scroll-margin-top: 2rem;">
        <div style={`width: 32px; height: 4px; background: ${cat.color}; border-radius: 2px; margin-bottom: 1rem;`}></div>
        <h2 style="font-size: 1.1rem; margin: 0 0 0.3rem; font-family: 'Playfair Display', serif; color: #2C2416;">{cat.title}</h2>
        <p style="font-size: 0.85rem; color: #8B7355; margin: 0 0 1.5rem;">{cat.desc}</p>
        <div style="display: flex; flex-direction: column; gap: 0;">
          {cat.items.map((item, i) => (
            <a href={`/ressources/${cat.id}/${item.slug}`} style={`display: flex; justify-content: space-between; align-items: center; padding: 1rem 0; border-top: 1px solid #D4C9B5; ${i === cat.items.length - 1 ? 'border-bottom: 1px solid #D4C9B5;' : ''} color: #2C2416; text-decoration: none;`}>
              <div>
                <span style="font-size: 0.9rem; font-weight: 500; font-family: monospace; margin-right: 1rem;">{item.name}</span>
                <span style="font-size: 0.85rem; color: #8B7355;">{item.desc}</span>
              </div>
              <span style="color: #8B7355; flex-shrink: 0; margin-left: 1rem;">→</span>
            </a>
          ))}
        </div>
      </section>
    ))}

  </div>
</Layout>
